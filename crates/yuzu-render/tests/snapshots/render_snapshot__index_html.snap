<!DOCTYPE html>
<html lang="ja" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ホーム | Fixture Docs</title>
<meta name="description" content="フィクスチャのトップページ">

<link rel="stylesheet" href="/docs/_assets/css/theme.css">
<link rel="stylesheet" href="/docs/_assets/css/syntect.css">
<script>
// FOUC 回避: CSS 適用前に保存済みテーマ（なければ OS 設定）を反映する
(function () {
  var stored = null;
  try { stored = localStorage.getItem("yuzu-theme"); } catch (e) {}
  var theme = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
  document.documentElement.dataset.theme = theme;
})();
</script>
</head>
<body>
