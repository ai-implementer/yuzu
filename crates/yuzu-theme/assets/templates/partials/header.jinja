<header class="site-header">
<div class="header-left">
{# 狭幅用のナビ開閉。hidden は nav.js が解除する（JS 無効時は出さない） #}
<button id="nav-toggle" type="button" aria-label="ナビゲーションを開閉"
        aria-controls="site-sidebar" aria-expanded="false" hidden>☰</button>
<a class="site-title" href="{{ base_url | safe }}">{{ site.title }}</a>
</div>
<div class="header-tools">
{% if search_enabled %}<div class="search" id="yuzu-search">
<input type="search" id="yuzu-search-input" placeholder="検索 ( / )" autocomplete="off"
       role="combobox" aria-expanded="false" aria-controls="yuzu-search-results">
<div class="search-results" id="yuzu-search-results" role="listbox" hidden></div>
</div>
{% endif %}{% if dark_enabled %}<button id="theme-toggle" type="button" aria-label="ダークモード切替" title="ダークモード切替">◐</button>
{% endif %}</div>
</header>
