<svg class="tankan tankan-state" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 131.5 403" width="131.5" height="403" role="img" aria-label="State diagram" font-family="sans-serif" font-size="14">
<style>
.tankan text { fill: #1f2328; }
