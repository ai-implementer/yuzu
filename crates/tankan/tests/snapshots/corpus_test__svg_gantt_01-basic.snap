<svg class="tankan tankan-gantt" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1025 218" width="1025" height="218" role="img" aria-label="A Gantt Diagram" font-family="sans-serif" font-size="14">
<style>
.tankan text { fill: #1f2328; }
.tankan .tk-title { font-weight: bold; }
.tankan .tk-section-band { fill: #f6f8fa; opacity: 0.5; }
.tankan .tk-section-label { fill: #59636e; }
.tankan .tk-grid { stroke: #d1d9e0; }
.tankan .tk-axis-label { fill: #59636e; }
.tankan .tk-excluded { fill: #f6f8fa; opacity: 0.7; }
.tankan .tk-task { fill: #f6f8fa; stroke: #d1d9e0; }
.tankan .tk-task-active { fill: #ffffff; stroke: #9a6700; }
.tankan .tk-task-done { fill: #d1d9e0; stroke: #d1d9e0; }
.tankan .tk-task-crit { stroke: #9a6700; stroke-width: 2; }
.tankan .tk-milestone { fill: #9a6700; stroke: #d1d9e0; }
.tankan .tk-task-name-done { fill: #59636e; }
</style>
